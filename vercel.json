{
  "framework": "nextjs",
  "installCommand": "npm install --force --legacy-peer-deps --include=dev",
  "buildCommand": "npx prisma@5 generate && node scripts/force-build-pages.js && node scripts/generate-sitemap.js && next build",
  "public": true,
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=8192",
    "SKIP_ENV_VALIDATION": "true",
    "NEXT_TELEMETRY_DISABLED": "1",
    "NEXT_PUBLIC_DEMO_MODE": "false"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=8192",
      "NEXT_TELEMETRY_DISABLED": "1",
      "SKIP_ENV_VALIDATION": "true",
      "CI": "false"
    }
  },
  "regions": ["syd1"],
  "github": {
    "silent": true
  },
  "functions": {
    "app/api/cron/reddit-orchestrator/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/reddit-orchestrator",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/reddit-performance",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/gbp-poster",
      "schedule": "0 19 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/pitch-deck/presentation",
      "destination": "/pitch/investor"
    },
    {
      "source": "/pitch-deck",
      "destination": "/pitch"
    }
  ]
}
