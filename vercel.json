{
  "framework": "nextjs",
  "installCommand": "npm install --force --legacy-peer-deps",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "public": true,
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=8192",
    "DATABASE_URL": "file:./prod.db",
    "SKIP_ENV_VALIDATION": "true",
    "NEXT_TELEMETRY_DISABLED": "1",
    "NEXTAUTH_URL": "https://disaster-recovery-seven.vercel.app",
    "NEXTAUTH_SECRET": "LMUDdvl91SzvH84on2RBx820GPJX33z+ICkk66EQMpg=",
    "NEXT_PUBLIC_SITE_URL": "https://disaster-recovery-seven.vercel.app",
    "NEXT_PUBLIC_APP_URL": "https://disaster-recovery-seven.vercel.app",
    "NEXT_PUBLIC_DEMO_MODE": "false",
    "SKIP_BUILD_ERRORS": "true"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=8192",
      "DATABASE_URL": "file:./build.db",
      "NEXT_TELEMETRY_DISABLED": "1",
      "SKIP_ENV_VALIDATION": "true",
      "CI": "false",
      "NEXTAUTH_URL": "https://disaster-recovery-seven.vercel.app",
      "NEXTAUTH_SECRET": "LMUDdvl91SzvH84on2RBx820GPJX33z+ICkk66EQMpg=",
      "NEXT_PUBLIC_SITE_URL": "https://disaster-recovery-seven.vercel.app",
      "NEXT_PUBLIC_APP_URL": "https://disaster-recovery-seven.vercel.app",
      "NEXT_PUBLIC_DEMO_MODE": "false",
      "SKIP_BUILD_ERRORS": "true"
    }
  },
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 30,
      "memory": 1024
    },
    "src/app/**/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "src/app/**/route.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "regions": ["syd1"],
  "github": {
    "silent": true
  },
  "rewrites": [
    {
      "source": "/pitch-deck/presentation",
      "destination": "/pitch/investor"
    },
    {
      "source": "/pitch-deck",
      "destination": "/pitch"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
